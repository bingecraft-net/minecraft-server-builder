#!/usr/bin/env zsh

set -e

if [ -f cidfile ] ; then
  podman start $(cat cidfile)
else
  IMAGE_TAG=bingecraft-net/velocity

  mkdir -p backups

  podman build -t $IMAGE_TAG .
  podman run -di \
    -p 25565:25565 \
    -v $(readlink -f secrets):/home/minecraft/secrets \
    $IMAGE_TAG > cidfile
fi

podman logs --follow $(cat cidfile)
